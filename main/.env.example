# Local development example.
# Copy this file to .env and fill values in your private environment.

ENV=local
DEBUG=true
LOG_LEVEL=DEBUG
LOG_PATH=./log/server.log

CN_API_KEY=sk-REPLACE_ME
CN_BASE_URL=https://example.com/

GLOBAL_API_KEY=sk-REPLACE_ME
GLOBAL_BASE_URL=https://example.com/

MYSQL_HOST=MYSQL_HOST
MYSQL_USER=MYSQL_USER
MYSQL_PASSWORD=REPLACE_ME

ALIYUN_ACCESS_KEY_ID=REPLACE_ME
ALIYUN_ACCESS_KEY_SECRET=REPLACE_ME
ALIYUN_OSS_BUCKET=REPLACE_ME
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_REGION=cn-beijing

IMG_URL_REPLACE=false
